# Copy to loki-s3-secret.yaml (gitignored), set real values, then:
#   kubectl -n monitoring apply -f loki-s3-secret.yaml
# These map to the standard AWS env vars Loki's S3 client reads.
apiVersion: v1
kind: Secret
metadata:
  name: loki-s3-secret
  namespace: monitoring
type: Opaque
stringData:
  AWS_ACCESS_KEY_ID: CHANGE_ME
  AWS_SECRET_ACCESS_KEY: CHANGE_ME
